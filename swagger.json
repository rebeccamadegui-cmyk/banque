{
  "openapi": "3.0.3",
  "info": {
    "title": "API Banque Complète",
    "description": "API complète pour gérer les comptes bancaires avec opérations financières",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api.php": {
      "get": {
        "summary": "Lister tous les comptes",
        "responses": {
          "200": {
            "description": "Liste des comptes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Compte"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer un nouveau compte",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulaire": {
                    "type": "string",
                    "description": "Nom du titulaire du compte",
                    "example": "Jean Dupont"
                  }
                },
                "required": ["titulaire"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compte créé avec succès",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Compte cree avec succes"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erreur de validation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Le nom du titulaire est requis"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api.php?id={id}": {
      "get": {
        "summary": "Consulter un compte spécifique",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte à consulter"
          }
        ],
        "responses": {
          "200": {
            "description": "Détails du compte avec transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    },
                    "transactions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Compte non trouvé",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Compte non trouvé"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Mettre à jour un compte",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte à modifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulaire": {
                    "type": "string",
                    "description": "Nouveau nom du titulaire",
                    "example": "Marie Dupont"
                  }
                },
                "required": ["titulaire"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compte mis à jour",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Compte mis à jour avec succès"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Compte non trouvé"
          }
        }
      },
      "delete": {
        "summary": "Supprimer un compte",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte à supprimer"
          }
        ],
        "responses": {
          "200": {
            "description": "Compte supprimé",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Compte supprimé avec succès"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Compte non trouvé"
          }
        }
      }
    },
    "/api.php?id={id}&action=depot": {
      "post": {
        "summary": "Effectuer un dépôt",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["depot"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "montant": {
                    "type": "number",
                    "description": "Montant à déposer",
                    "example": 100.5
                  },
                  "description": {
                    "type": "string",
                    "description": "Description de l'opération",
                    "example": "Salaire"
                  }
                },
                "required": ["montant"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dépôt effectué",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Dépôt effectué avec succès"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Montant invalide"
          },
          "404": {
            "description": "Compte non trouvé"
          }
        }
      }
    },
    "/api.php?id={id}&action=retrait": {
      "post": {
        "summary": "Effectuer un retrait",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["retrait"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "montant": {
                    "type": "number",
                    "description": "Montant à retirer",
                    "example": 50.0
                  },
                  "description": {
                    "type": "string",
                    "description": "Description de l'opération",
                    "example": "Courses"
                  }
                },
                "required": ["montant"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retrait effectué",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Retrait effectué avec succès"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Montant invalide ou solde insuffisant"
          },
          "404": {
            "description": "Compte non trouvé"
          }
        }
      }
    },
    "/api.php?id={id}&action=virement": {
      "post": {
        "summary": "Effectuer un virement",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte source"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["virement"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "montant": {
                    "type": "number",
                    "description": "Montant à virer",
                    "example": 200.0
                  },
                  "compte_destinataire": {
                    "type": "integer",
                    "description": "ID du compte destinataire",
                    "example": 1775923632
                  },
                  "description": {
                    "type": "string",
                    "description": "Description du virement",
                    "example": "Paiement loyer"
                  }
                },
                "required": ["montant", "compte_destinataire"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Virement effectué",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Virement effectué avec succès"
                    },
                    "compte_source": {
                      "$ref": "#/components/schemas/Compte"
                    },
                    "compte_destinataire": {
                      "$ref": "#/components/schemas/Compte"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Données invalides ou solde insuffisant"
          },
          "404": {
            "description": "Compte source ou destinataire non trouvé"
          }
        }
      }
    },
    "/api.php?id={id}&action=transfert_service": {
      "post": {
        "summary": "Transférer de l'argent vers un service (OM, MOMO, UBA)",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte source"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["transfert_service"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "montant": {
                    "type": "number",
                    "description": "Montant à transférer",
                    "example": 50000
                  },
                  "service_destination": {
                    "type": "string",
                    "enum": ["OM", "MOMO", "UBA"],
                    "description": "Service destinataire",
                    "example": "OM"
                  },
                  "service_origine": {
                    "type": "string",
                    "description": "Service d'origine (optionnel, défaut: BANQUE)",
                    "example": "BANQUE"
                  },
                  "numero_beneficiaire": {
                    "type": "string",
                    "description": "Numéro du bénéficiaire (optionnel)",
                    "example": "+237681234567"
                  }
                },
                "required": ["montant", "service_destination"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfert vers service effectué",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string"
                    },
                    "compte": {
                      "$ref": "#/components/schemas/Compte"
                    },
                    "details": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erreur de transfert"
          }
        }
      }
    },
    "/api.php?id={id}&action=reception_service": {
      "post": {
        "summary": "Recevoir de l'argent d'un service (OM, MOMO, UBA)",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID du compte récepteur"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["reception_service"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "montant": {
                    "type": "number",
                    "description": "Montant reçu",
                    "example": 50000
                  },
                  "service_origine": {
                    "type": "string",
                    "enum": ["OM", "MOMO", "UBA"],
                    "description": "Service d'origine",
                    "example": "MOMO"
                  },
                  "numero_emetteur": {
                    "type": "string",
                    "description": "Numéro de l'émetteur (optionnel)",
                    "example": "+237681234567"
                  }
                },
                "required": ["montant", "service_origine"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fonds reçus avec succès"
          }
        }
      }
    },
    "/api.php?action=transactions_service&service={service}": {
      "get": {
        "summary": "Lister les transactions d'un service",
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["transactions_service"]
            }
          },
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["OM", "MOMO", "UBA"]
            },
            "description": "Filtre par service"
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions du service"
          }
        }
      }
    },
    "/api.php?action=services": {
      "get": {
        "summary": "Lister les services supportés",
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["services"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liste des services",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "services": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "example": ["OM", "MOMO", "UBA"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api.php?action=transactions": {
      "get": {
        "summary": "Lister toutes les transactions",
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["transactions"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liste de toutes les transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Compte": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID unique du compte",
            "example": 1775923632
          },
          "numero": {
            "type": "string",
            "description": "Numéro du compte",
            "example": "FR8712BANK"
          },
          "titulaire": {
            "type": "string",
            "description": "Nom du titulaire",
            "example": "Marie Claire"
          },
          "solde": {
            "type": "number",
            "description": "Solde du compte",
            "example": 1500.5
          },
          "service": {
            "type": "string",
            "description": "Service associé au compte",
            "enum": ["BANQUE", "OM", "MOMO", "UBA"],
            "example": "BANQUE"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID unique de la transaction",
            "example": "17759236321547"
          },
          "compte_id": {
            "type": "integer",
            "description": "ID du compte concerné",
            "example": 1775923632
          },
          "type": {
            "type": "string",
            "enum": [
              "depot",
              "retrait",
              "virement_entrant",
              "virement_sortant",
              "transfert_service_entrant",
              "transfert_service_sortant"
            ],
            "description": "Type de transaction",
            "example": "depot"
          },
          "montant": {
            "type": "number",
            "description": "Montant de la transaction (positif pour crédit, négatif pour débit)",
            "example": 100.5
          },
          "description": {
            "type": "string",
            "description": "Description de la transaction",
            "example": "Dépôt salaire"
          },
          "service": {
            "type": "string",
            "enum": ["OM", "MOMO", "UBA", "BANQUE"],
            "description": "Service d'origine",
            "example": "OM"
          },
          "service_destination": {
            "type": "string",
            "enum": ["OM", "MOMO", "UBA", "BANQUE"],
            "description": "Service de destination",
            "example": "MOMO"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Date et heure de la transaction",
            "example": "2024-01-15 14:30:25"
          }
        }
      }
    }
  }
}
